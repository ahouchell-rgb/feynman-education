# Feynman Education — env example. Copy to .env.local (gitignored) and fill.
# NEXT_PUBLIC_* are exposed to the browser; everything else is server-only.

# Origin of the retrieval-app, used to deep-link / embed retrieval practice in a
# lesson (see src/components/RetrievalAppFrame.tsx).
# Confirmed: this is the retrieval-app production domain (Vercel).
NEXT_PUBLIC_RETRIEVAL_APP_ORIGIN=https://retrieval-app.com

# --- Server-only secrets: set these in Vercel, never commit real values ---
# ANTHROPIC_API_KEY=            # used by /api/chat-with-lesson and /api/feedforward
# SUPABASE_SERVICE_ROLE_KEY=    # used for token-usage logging + OAuth token writes

# --- Cron + retrieval data (half-term feedforward + weekly parent reports) ---
# CRON_SECRET=                  # bearer the Vercel cron presents to the /api/cron/* routes
# SK_API_KEY=                   # x-sciencekit-key secret gating the retrieval RPCs (weak topics)

# --- Weekly parent progress reports (/api/cron/weekly-parent-report) ---
# Emailing is OPTIONAL: without these the report is still generated + persisted,
# just not sent. Uses Resend (https://resend.com) via plain fetch — no SDK.
# RESEND_API_KEY=
# PARENT_REPORT_FROM=           # verified From, e.g. "Feynman <hi@feynman.education>"
# This app's own public URL — used to build the parent-portal + unsubscribe
# links inside report emails (/parent?t=… and /parent/unsubscribe?t=…). Without
# it those links are omitted (the report still sends).
# NEXT_PUBLIC_APP_ORIGIN=        # e.g. https://app.feynman.education

# --- Google Drive (import Google Slides / save decks back as .pptx) ---
# In Google Cloud Console: create an OAuth 2.0 Client (type "Web application")
# and an API key; enable the Google Drive API + Google Picker API; add
# https://<your-domain>/api/google/callback (and
# http://localhost:3000/api/google/callback for dev) as authorized redirect URIs.
# Scope requested is drive.file only (per-file access, no full-Drive review).
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_STATE_SECRET=            # optional; falls back to GOOGLE_CLIENT_SECRET for HMAC state
# NEXT_PUBLIC_GOOGLE_API_KEY=     # browser API key for the Google Picker
# NEXT_PUBLIC_GOOGLE_APP_ID=      # optional: GCP project number (enables shared-drive picking)
