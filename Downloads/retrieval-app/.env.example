# Retrieval-app config. Copy to .env.local (gitignored) to override.
# These are the PUBLIC Supabase project URL + anon key (safe to expose to the
# browser; row-level security protects the data). Setting them here lets you
# rotate the key or point at another project without editing source.
NEXT_PUBLIC_SUPA_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPA_KEY=your-anon-key

# Origins allowed to embed this app in an <iframe> (the ScienceKit lesson page).
# Space-separated. FILL with your ScienceKit prod / preview / local origins.
ALLOWED_FRAME_ANCESTORS=https://sciencekit.vercel.app https://*.vercel.app http://localhost:3000
