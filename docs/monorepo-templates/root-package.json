{
  "name": "feynman",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@9.12.3",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "apps/feynman",
    "apps/retrieval",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "build:interactive": "python3 apps/interactive/build.py"
  },
  "devDependencies": {
    "turbo": "^2.10.0"
  }
}
